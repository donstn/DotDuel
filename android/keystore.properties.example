# Copy this file to android/keystore.properties and fill in the real values.
# keystore.properties and the .jks file itself are gitignored — NEVER commit
# them. Losing the .jks (or its passwords) means you can never update the app
# on Google Play again, so keep at least two offline copies (USB stick, cloud
# drive with strong password).
#
# Create the keystore once with (any folder OUTSIDE the repo, e.g. Documents):
#   keytool -genkey -v -keystore C:\Users\onemu\Documents\dotduel-upload.jks ^
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile is resolved relative to the android/ folder; an absolute path is
# safest on Windows (use forward slashes).
storeFile=C:/Users/onemu/Documents/dotduel-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
