{
  "rules": {
    ".read": false,
    ".write": false,
    "games": {
      "$gameId": {
        ".read": "auth != null && (root.child('games').child($gameId).child('playerUids').child('1').val() === auth.uid || root.child('games').child($gameId).child('playerUids').child('2').val() === auth.uid)",
        "pendingMove": {
          ".write": "auth != null && (root.child('games').child($gameId).child('playerUids').child('1').val() === auth.uid || root.child('games').child($gameId).child('playerUids').child('2').val() === auth.uid)"
        },
        "state": { ".write": false },
        "clock": { ".write": false },
        "error": { ".write": false },
        "playerUids": { ".write": false },
        "status": { ".write": false },
        "winner": { ".write": false },
        "ready": {
          "$slot": {
            ".write": "auth != null && root.child('games').child($gameId).child('playerUids').child($slot).val() === auth.uid && (newData.val() === true || newData.val() === false)"
          }
        },
        "$other": { ".write": false }
      }
    }
  }
}
