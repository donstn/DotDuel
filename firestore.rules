rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user profile + cloud-synced progression. Only the owner reads or writes.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Username claims. Anyone signed-in may read (for availability checks).
    // Only the owning uid may create / update / delete their own claim.
    match /usernames/{lower} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

  }
}
