rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user profile + cloud-synced progression.
    // - Read: owner only.
    // - Create: owner only (first-time write via claimUsername — every
    //   initial field allowed).
    // - Update: owner only AND restricted to a narrow allow-list of
    //   user-controlled fields. Fields like rating, placementGamesPlayed,
    //   email, authProvider, createdAt are writable ONLY by Cloud
    //   Functions (Admin SDK bypasses rules). Prevents a malicious user
    //   from self-granting rating or shape unlocks.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      // Two allowed update shapes:
      //   1. Normal player-controlled update — only displayName/progress
      //      may change (rating, email, authProvider, createdAt remain
      //      function-only).
      //   2. First-time profile completion — when the doc exists but has
      //      no displayName yet (e.g. a stale {progress}-only partial
      //      from a previous client version), allow the same fields the
      //      create rule would have allowed. Gated by displayName being
      //      absent so it cannot be replayed after the username is set.
      allow update: if request.auth != null && request.auth.uid == uid
        && (
          request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'progress', 'challengePolicy', 'showPresence', 'friendListHidden', 'streak'])
          ||
          (!('displayName' in resource.data) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'email', 'authProvider', 'createdAt', 'progress']))
        );
      allow delete: if false;  // account deletion goes through deleteAccount Cloud Function

      // Phase 2b (Alpha 0.2.6.0) — daily-puzzle attempts. Each attempt is
      // a doc keyed by UTC date. Owner-only read/write; no deletes (audit
      // trail). v1 trusts the client to write margin honestly; a Cloud
      // Function validator can be added later if a leaderboard ships.
      match /dailyPuzzles/{utcDate} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    // Phase 2b-v2 (Alpha 0.2.7.0) — public daily-puzzle leaderboard.
    // Any signed-in user may read entries for any date (the leaderboard is
    // the whole point); only the owning uid may write their own entry.
    // No deletes. v2 trusts the client-written margin; a server validator
    // is the obvious follow-up if cheating shows up.
    match /dailyLeaderboard/{utcDate}/entries/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Username claims. Anyone signed-in may read (for availability checks).
    // Only the owning uid may create / update / delete their own claim.
    match /usernames/{lower} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Matchmaking queue. Each player can only create / read / delete
    // their own entry. The matchmake Cloud Function (admin SDK) bypasses
    // these rules to read the whole queue and pair players.
    match /matchmakingQueue/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Pairing notifications. Each player can read their own. Functions write.
    match /pairings/{uid} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Match records. Any signed-in user can read (for replays / history).
    // Only functions write.
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Global leaderboard (denormalised). Public-readable fields only —
    // displayName, rating, placementGamesPlayed, totalGames, lastPlayedAt.
    // Functions write inside the finalizeGame transaction so the entry
    // always reflects the latest match outcome.
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // GDPR Article 17 audit log — records that an account was deleted
    // (hashed sentinel only, no PII). Written by the deleteAccount
    // Cloud Function. No client access at all.
    match /deletionLog/{sentinel} {
      allow read, write: if false;
    }

    // Invite codes for private games. Anyone signed-in can read to look up
    // a code; functions create + delete. (Phase C.2 will populate these.)
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // M-3: per-uid rate-limit token buckets. Function-only access; the
    // enforceRateLimit helper updates these docs via Admin SDK.
    match /rateLimits/{bucketId} {
      allow read, write: if false;
    }

    // Bot Army — private metadata for the AI opponents (level, think
    // delay range, active flag). Client never reads this directly; the
    // public-facing fields (displayName, rating, isBot, botLevel) are
    // mirrored to users/{botUid} (still owner-gated) and leaderboard/{botUid}
    // (signed-in-readable) which existing rules already cover.
    match /bots/{botUid} {
      allow read, write: if false;
    }

    // Per-uid multiplayer session lock. Carries the sessionId of whichever
    // tab/device is "the active one" for a given account, plus a heartbeat
    // timestamp other tabs read to detect a stale (crashed) claim. The same
    // user is the only reader/writer — other accounts have no business with
    // someone else's session. Replaced the RTDB gameSessions/{uid} lock to
    // work on networks that block *.firebasedatabase.app.
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Friendships. Doc ID is `sorted([uidA, uidB]).join('__')` so each pair
    // is uniquely keyed. Either participant can read; only Cloud Functions
    // write (so we can enforce policy + symmetric updates atomically).
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
        && resource != null
        && request.auth.uid in resource.data.uids;
      allow write: if false;
    }

    // Game invites. Sender or recipient can read their own invites; only
    // Cloud Functions write (the multi-invite race transaction needs to
    // touch sibling docs atomically).
    match /invites/{inviteId} {
      allow read: if request.auth != null
        && resource != null
        && (resource.data.from == request.auth.uid
            || resource.data.to == request.auth.uid);
      allow write: if false;
    }

    // Per-user block list. Unilateral — blocker writes their own
    // /blocks/{uid}/blockedUids/{blockedUid} entry. Blocked user is never
    // notified and never reads this. Cloud Functions consult these docs
    // when validating friend requests / invites.
    match /blocks/{uid}/blockedUids/{blockedUid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Presence — a denormalised mirror of the user's session status
    // (`menu` / `in-ai` / `in-hotseat` / `in-ranked` / `searching-ranked`)
    // that friends are allowed to read. sessions/{uid} stays owner-only;
    // this doc is the only friend-readable status surface. Owner writes
    // only status/statusUpdatedAt/lastSeen — Cloud Functions maintain the
    // friendUids array via the friendship accept/remove path (Admin SDK
    // bypasses these rules).
    match /presence/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || (resource != null
                && 'friendUids' in resource.data
                && request.auth.uid in resource.data.friendUids));
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys()
             .hasOnly(['status', 'statusUpdatedAt', 'lastSeen']);
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'statusUpdatedAt', 'lastSeen']);
      allow delete: if false;
    }

    // Live game state. Mirrors the RTDB games/{gameId} node during the
    // Firestore migration (MULTIPLAYER_BACKEND = 'dual' or 'firestore').
    // Read: participants only — same semantics as the RTDB rule.
    // Write: function-only. Client-driven actions go through callable
    // functions (submitMove, setReady, etc., added in later migration
    // phases); direct client writes never happen.
    match /games/{gameId} {
      allow read: if request.auth != null &&
        (resource.data.playerUids['1'] == request.auth.uid ||
         resource.data.playerUids['2'] == request.auth.uid);
      allow write: if false;
    }

  }
}
